{
  "name": "fitsphere-expo-go",
  "version": "1.0.0",
  "description": "FitSphere - A comprehensive e-commerce fitness app built with React Native and Expo",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --port 8081",
